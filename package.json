{
  "name": "uptime-kuma",
  "version": "1.0.0",
  "description": "A fancy self-hosted monitoring tool",
  "author": "Louis Lam",
  "license": "MIT",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "dev-frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "start:pi": "NODE_ENV=production PORT=3001 node server/server.js"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.3.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.9",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.1",
    "knex": "^2.5.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "ping": "^0.4.4",
    "socket.io": "^4.7.1",
    "socket.io-client": "^4.7.1",
    "sqlite3": "^5.1.6",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "eslint": "^8.46.0",
    "eslint-plugin-vue": "^9.17.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "vite": "^4.4.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "uptime",
    "monitoring",
    "self-hosted",
    "status-page"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/louislam/uptime-kuma.git"
  },
  "_personal_notes": "my personal fork for home server use - running on a raspberry pi 4. use 'npm run start:pi' to launch with the correct port (3001) since 3000 is taken by another service on the pi"
}
